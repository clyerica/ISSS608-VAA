          <datasource-dependencies datasource='Parameters'>
            <column caption='# of Std Dev' datatype='integer' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='1'>
              <calculation class='tableau' formula='1' />
              <range granularity='1' max='3' min='1' />
            </column>
