              </calculation>
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column caption='Lower Control Limit' datatype='real' name='[Upper Control Limit (copy)_2612758143176707]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(SUM([Sales])) - (WINDOW_STDEV(SUM([Sales]))*[Parameters].[Parameter 1])'>
