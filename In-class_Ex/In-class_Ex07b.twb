          <datasource-dependencies datasource='federated.0ypoh991famyse1drab9u18tfrtm'>
            <column caption='Upper Control Limit' datatype='real' name='[Calculation_2612758141968386]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(SUM([Sales])) + WINDOW_STDEV(SUM([Sales]))*[Parameters].[Parameter 1]'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Out of Control Limit' datatype='real' name='[Calculation_2612758144708612]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Sales])&gt; [Calculation_2612758141968386]&#13;&#10;OR SUM([Sales])&lt; [Upper Control Limit (copy)_2612758143176707]&#13;&#10;THEN SUM([Sales]) &#13;&#10;END'>
